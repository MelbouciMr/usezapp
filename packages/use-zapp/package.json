{
  "name": "use-zapp",
  "version": "0.1.0",
  "description": "React SDK for private payments via the ZAPP Protocol shielded pool on Ethereum",
  "main":    "src/index.ts",
  "types":   "src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "files": ["src", "README.md"],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev":   "tsup src/index.ts --format cjs,esm --dts --watch",
    "lint":  "tsc --noEmit"
  },
  "keywords": ["zapp", "shielded-pool", "zero-knowledge", "privacy", "ethereum", "payments", "react", "x402"],
  "license": "MIT",
  "peerDependencies": {
    "react": ">=18",
    "viem":  ">=2"
  },
  "devDependencies": {
    "tsup":       "^8.0.0",
    "typescript": "^5.4.0",
    "viem":       "^2.17.0"
  }
}
